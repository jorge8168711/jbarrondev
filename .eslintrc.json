{
  "extends": ["airbnb", "airbnb/hooks", "plugin:prettier/recommended"],
  "rules": {
    "prettier/prettier": [
      "warn",
      {
        "trailingComma": "none",
        "tabWidth": 2,
        "semi": true,
        "singleQuote": true,
        "jsxSingleQuote": true,
        "jsxBracketSameLine": true,
        "printWidth": 100
      }
    ],
    "no-console": "off",
    "no-unused-vars": "warn",
    "react/jsx-closing-bracket-location": [1, {
      "nonEmpty": false,
      "selfClosing": false
    }]
  },
  "env": {
    "browser": true
  }
}
